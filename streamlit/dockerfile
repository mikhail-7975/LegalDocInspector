# Используем официальный Python 3.11 slim образ
FROM python:3.11-slim

# Установка системных зависимостей
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
    && rm -rf /var/lib/apt/lists/*

# Установка uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# Устанавливаем рабочую директорию
WORKDIR /app

# Копируем файлы конфигурации
COPY requirements.txt .

# Создание виртуального окружения и установка зависимостей через uv
RUN uv venv && \
    uv pip install -r requirements.txt

# Копируем исходный код приложения
COPY . .

# Создание пользователя без прав root
RUN useradd --create-home --shell /bin/bash streamlit && \
    chown -R streamlit:streamlit /app
USER streamlit

# Указываем порт для Streamlit
EXPOSE 8501

# Настройки Streamlit
ENV STREAMLIT_SERVER_PORT=8501
ENV STREAMLIT_SERVER_ADDRESS=0.0.0.0
ENV STREAMLIT_SERVER_HEADLESS=true
ENV STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
ENV UV_SYSTEM_PYTHON=1

# Health check для Streamlit
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

# Команда запуска через uv
CMD ["uv", "run", "streamlit", "run", "interface.py", "--server.port=8501", "--server.address=0.0.0.0"]
